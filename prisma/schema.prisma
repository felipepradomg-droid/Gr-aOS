// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTENTICAÇÃO
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?

  plan          String    @default("free")
  planExpiresAt DateTime?
  trialEndsAt   DateTime?

  accounts          Account[]
  sessions          Session[]
  payments          Payment[]
  cotacoes          Cotacao[]
  companyFiscalConfig CompanyFiscalConfig?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  mpPaymentId String   @unique
  planId      String
  amount      Float
  status      String   @default("pending")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// COTAÇÕES
// ============================================================

model Cotacao {
  id           String  @id @default(cuid())
  userId       String
  clienteNome  String
  clienteEmail String?
  clienteTel   String?
  descricao    String  @db.Text
  valor        Float?
  status       String  @default("rascunho")
  observacoes  String? @db.Text

  equipmentId  String?
  equipment    Equipment? @relation(fields: [equipmentId], references: [id])

  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  serviceOrder ServiceOrder?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// FROTA
// ============================================================

model Equipment {
  id           String  @id @default(cuid())
  userId       String
  name         String
  type         String
  brand        String?
  model        String?
  year         Int?
  plate        String?
  serialNumber String?
  capacityTons Float?
  status       String  @default("available")
  dailyRate    Float?
  hourlyRate   Float?
  notes        String? @db.Text

  photos        EquipmentPhoto[]
  documents     EquipmentDocument[]
  specs         EquipmentSpec[]
  bookings      Booking[]
  serviceOrders ServiceOrder[]
  maintenance   MaintenanceRecord[]
  cotacoes      Cotacao[]

  hourMeters        HourMeter[]
  maintenancePlans  MaintenancePlan[]
  maintenanceAlerts MaintenanceAlert[]
  equipmentCosts    EquipmentCost[]
  contracts         Contract[]
  fuelSupplies      FuelSupply[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EquipmentPhoto {
  id          String    @id @default(cuid())
  equipmentId String
  url         String
  isCover     Boolean   @default(false)
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model EquipmentDocument {
  id          String    @id @default(cuid())
  equipmentId String
  docType     String
  name        String
  url         String
  expiresAt   DateTime?
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model EquipmentSpec {
  id          String    @id @default(cuid())
  equipmentId String
  key         String
  value       String
  unit        String?
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
}

// ============================================================
// AGENDAMENTOS
// ============================================================

model Booking {
  id          String    @id @default(cuid())
  userId      String
  equipmentId String
  title       String
  startDate   DateTime
  endDate     DateTime
  bookingType String    @default("confirmed")
  notes       String?   @db.Text
  clientName  String?

  equipment    Equipment     @relation(fields: [equipmentId], references: [id])
  serviceOrder ServiceOrder?

  createdAt DateTime @default(now())
}

// ============================================================
// ORDENS DE SERVIÇO
// ============================================================

model ServiceOrder {
  id             String    @id @default(cuid())
  userId         String
  osNumber       String    @unique
  cotacaoId      String?   @unique
  equipmentId    String
  bookingId      String?   @unique
  clienteNome    String
  clienteTel     String?
  operatorName   String?
  status         String    @default("pending")

  startDate      DateTime
  endDate        DateTime
  actualStart    DateTime?
  actualEnd      DateTime?

  serviceAddress String?
  serviceCity    String?
  serviceNotes   String?   @db.Text

  totalDays      Int?
  dailyRate      Float?
  totalAmount    Float?

  cotacao        Cotacao?  @relation(fields: [cotacaoId], references: [id])
  equipment      Equipment @relation(fields: [equipmentId], references: [id])
  booking        Booking?  @relation(fields: [bookingId], references: [id])
  invoice        Invoice?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ============================================================
// MANUTENÇÃO
// ============================================================

model MaintenanceRecord {
  id              String    @id @default(cuid())
  userId          String
  equipmentId     String
  maintenanceType String
  description     String    @db.Text
  provider        String?
  cost            Float?
  startDate       DateTime
  endDate         DateTime?
  hoursAtService  Float?
  status          String    @default("scheduled")
  notes           String?   @db.Text

  equipment       Equipment @relation(fields: [equipmentId], references: [id])

  createdAt       DateTime  @default(now())
}

// ============================================================
// FATURAS
// ============================================================

model Invoice {
  id             String    @id @default(cuid())
  userId         String
  invoiceNumber  String    @unique
  serviceOrderId String?   @unique
  clienteNome    String
  clienteTel     String?
  clienteEmail   String?
  clienteCnpjCpf String?
  status         String    @default("draft")

  issueDate      DateTime  @default(now())
  dueDate        DateTime
  amount         Float
  taxAmount      Float     @default(0)
  totalAmount    Float
  paymentMethod  String?
  paidAt         DateTime?
  notes          String?   @db.Text

  municipalityConfigId String?
  municipalityConfig   MunicipalityTaxConfig? @relation(fields: [municipalityConfigId], references: [id])

  rpsNumber            Int?
  rpsSeries            String?
  nfseNumber           String?
  nfseVerificationCode String?
  nfsePdfUrl           String?
  nfseXml              String?   @db.Text
  providerProtocol     String?
  providerResponse     Json?
  errorMessage         String?   @db.Text
  emittedAt            DateTime?
  cancelledAt          DateTime?
  whatsappSentAt       DateTime?
  whatsappMessageId    String?

  serviceOrder   ServiceOrder? @relation(fields: [serviceOrderId], references: [id])
  receivable     Receivable?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ============================================================
// FISCAL — Configuração por Município
// ============================================================

model NfseProvider {
  id           String  @id @default(cuid())
  name         String  @unique
  baseUrl      String
  authType     String
  isActive     Boolean @default(true)

  municipalities MunicipalityTaxConfig[]

  createdAt DateTime @default(now())
}

model MunicipalityTaxConfig {
  id          String  @id @default(cuid())
  ibgeCode    String  @unique
  cityName    String
  state       String  @db.Char(2)
  providerId  String
  provider    NfseProvider @relation(fields: [providerId], references: [id])

  providerCredentials Json?
  issRate            Float?
  serviceCode        String?
  serviceDescription String?
  requiresRps        Boolean @default(true)
  nfseEnvironment    String  @default("homologacao")
  isActive           Boolean @default(true)

  invoices           Invoice[]
  companyConfigs     CompanyFiscalConfig[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// FISCAL — Configuração da Empresa (por locadora)
// ============================================================

model CompanyFiscalConfig {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  municipalityConfigId String
  municipalityConfig   MunicipalityTaxConfig @relation(fields: [municipalityConfigId], references: [id])

  nfeApiKey    String
  nfeCompanyId String

  razaoSocial        String?
  cnpj               String?
  inscricaoMunicipal String?
  codigoServico      String?
  aliquotaIss        Float?

  ambiente     String  @default("homologacao")
  ativo        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// FINANCEIRO — Contas Bancárias
// ============================================================

model BankAccount {
  id            String  @id @default(cuid())
  userId        String
  bankName      String
  bankCode      String?
  agency        String?
  accountNumber String?
  accountType   String?

  integrationType   String?
  apiCredentials    Json?
  externalAccountId String?

  currentBalance   Float     @default(0)
  balanceUpdatedAt DateTime?
  isActive         Boolean   @default(true)

  transactions BankTransaction[]
  receivables  Receivable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// FINANCEIRO — Títulos a Receber
// ============================================================

model Receivable {
  id            String  @id @default(cuid())
  userId        String
  invoiceId     String? @unique
  invoice       Invoice?     @relation(fields: [invoiceId], references: [id])
  bankAccountId String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])

  clienteNome    String
  clienteCnpjCpf String?
  paymentMethod  String
  amount         Float
  dueDate        DateTime

  externalId  String?  @unique
  barcode     String?  @db.Text
  pixKey      String?
  pixQrcode   String?  @db.Text
  paymentUrl  String?

  status            String   @default("pending")
  paidAmount        Float?
  paidAt            DateTime?
  paymentMethodUsed String?

  fineAmount     Float @default(0)
  interestAmount Float @default(0)
  discountAmount Float @default(0)

  bankTransactionId String?         @unique
  bankTransaction   BankTransaction? @relation(fields: [bankTransactionId], references: [id])
  reconciledAt      DateTime?
  reconciledBy      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// FINANCEIRO — Extrato Bancário
// ============================================================

model BankTransaction {
  id            String      @id @default(cuid())
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  userId        String

  transactionDate  DateTime
  description      String
  amount           Float
  balanceAfter     Float?

  externalId          String? @unique
  documentNumber      String?
  counterpartDocument String?
  counterpartName     String?
  paymentType         String?

  reconciliationStatus String @default("pending")
  confidenceScore      Float?

  receivable         Receivable?
  reconciliationLogs ReconciliationLog[]

  importedAt DateTime @default(now())
}

// ============================================================
// FINANCEIRO — Log de Conciliação
// ============================================================

model ReconciliationLog {
  id                String  @id @default(cuid())
  userId            String
  bankTransactionId String
  bankTransaction   BankTransaction @relation(fields: [bankTransactionId], references: [id])
  receivableId      String?

  action          String
  performedBy     String?
  confidenceScore Float?
  notes           String? @db.Text

  createdAt DateTime @default(now())
}

// ============================================================
// MANUTENÇÃO PREDITIVA
// ============================================================

model HourMeter {
  id          String    @id @default(cuid())
  userId      String
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  reading     Float
  readingDate DateTime  @default(now())
  recordedBy  String?
  notes       String?   @db.Text

  createdAt   DateTime  @default(now())
}

model MaintenancePlan {
  id          String    @id @default(cuid())
  userId      String
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  name          String
  triggerType   String  @default("hours")
  intervalHours Float?
  intervalDays  Int?

  lastDoneAt    DateTime?
  lastDoneHours Float?
  nextDueAt     DateTime?
  nextDueHours  Float?

  estimatedCost Float?
  status        String  @default("active")

  alerts        MaintenanceAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MaintenanceAlert {
  id          String    @id @default(cuid())
  userId      String
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  planId      String?
  plan        MaintenancePlan? @relation(fields: [planId], references: [id])

  alertType     String
  message       String
  triggeredAt   Float?
  dueDate       DateTime?

  status        String  @default("pending")
  resolvedAt    DateTime?
  blocksBooking Boolean @default(false)

  whatsappSentAt    DateTime?
  whatsappMessageId String?

  createdAt DateTime @default(now())
}

model EquipmentCost {
  id          String    @id @default(cuid())
  userId      String
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  costType    String
  description String
  amount      Float
  costDate    DateTime  @default(now())

  maintenanceRecordId String?

  createdAt DateTime @default(now())
}

// ============================================================
// CONTRATOS E MEDIÇÕES
// ============================================================

model Contract {
  id          String    @id @default(cuid())
  userId      String
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  contractNumber String  @unique
  clienteNome    String
  clienteTel     String?
  clienteEmail   String?
  clienteCnpjCpf String?

  billingType    String  @default("daily")
  rate           Float
  currency       String  @default("BRL")

  startDate      DateTime
  endDate        DateTime?
  status         String  @default("active")

  siteAddress    String?
  siteCity       String?
  operatorName   String?
  notes          String? @db.Text

  measurements   Measurement[]
  invoices       ContractInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Measurement {
  id         String   @id @default(cuid())
  userId     String
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id])

  measureDate  DateTime @default(now())
  hoursWorked  Float?
  daysWorked   Float?
  amount       Float
  operatorName String?
  notes        String? @db.Text

  status       String  @default("pending")

  createdAt DateTime @default(now())
}

model ContractInvoice {
  id         String   @id @default(cuid())
  userId     String
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id])

  periodStart   DateTime
  periodEnd     DateTime
  totalMeasured Float
  totalAmount   Float
  invoiceId     String?

  status      String  @default("draft")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// ABASTECIMENTO / CONTROLE DE COMBUSTÍVEL
// ============================================================

model FuelSupply {
  id          String    @id @default(cuid())
  userId      String
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  supplyDate    DateTime @default(now())
  fuelType      String   @default("diesel") // diesel | gasolina | etanol | arla
  liters        Float
  pricePerLiter Float
  totalCost     Float

  meterType    String  @default("hourmeter") // hourmeter | odometer
  meterReading Float?

  supplier      String?
  invoiceNumber String?
  operatorName  String?
  notes         String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
