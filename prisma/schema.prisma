generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTENTICAÇÃO
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?

  plan          String    @default("free")
  planExpiresAt DateTime?
  trialEndsAt   DateTime?

  accounts          Account[]
  sessions          Session[]
  payments          Payment[]
  cotacoes          Cotacao[]
  companyFiscalConfig CompanyFiscalConfig?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  mpPaymentId String   @unique
  planId      String
  amount      Float
  status      String   @default("pending")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// COTAÇÕES
// ============================================================

model Cotacao {
  id           String  @id @default(cuid())
  userId       String
  clienteNome  String
  clienteEmail String?
  clienteTel   String?
  descricao    String  @db.Text
  valor        Float?
  status       String  @default("rascunho")
  observacoes  String? @db.Text

  equipmentId  String?
  equipment    Equipment? @relation(fields: [equipmentId], references: [id])

  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  serviceOrder ServiceOrder?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// FROTA
// ============================================================

model Equipment {
  id           String  @id @default(cuid())
  userId       String
  name         String
  type         String
  brand        String?
  model        String?
  year         Int?
  plate        String?
  serialNumber String?
  capacityTons Float?
  status       String  @default("available")
  dailyRate    Float?
  hourlyRate   Float?
  notes        String? @db.Text

  photos        EquipmentPhoto[]
  documents     EquipmentDocument[]
  specs         EquipmentSpec[]
  bookings      Booking[]
  serviceOrders ServiceOrder[]
  maintenance   MaintenanceRecord[]
  cotacoes      Cotacao[]

  hourMeters        HourMeter[]
  maintenancePlans  MaintenancePlan[]
  maintenanceAlerts MaintenanceAlert[]
  equipmentCosts    EquipmentCost[]
  contracts         Contract[]
  fuelSupplies      FuelSupply[]
  operatorAssignments OperatorAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EquipmentPhoto {
  id          String    @id @default(cuid())
  equipmentId String
  url         String
  isCover     Boolean   @default(false)
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model EquipmentDocument {
  id          String    @id @default(cuid())
  equipmentId String
  docType     String
  name        String
  url         String
  expiresAt   DateTime?
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model EquipmentSpec {
  id          String    @id @default(cuid())
  equipmentId String
  key         String
  value       String
  unit        String?
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
}

// ============================================================
// AGENDAMENTOS
// ============================================================

model Booking {
  id          String    @id @default(cuid())
  userId      String
  equipmentId String
  title       String
  startDate   DateTime
  endDate     DateTime
  bookingType String    @default("confirmed")
  notes       String?   @db.Text
  clientName  String?

  equipment    Equipment     @relation(fields: [equipmentId], references: [id])
  serviceOrder ServiceOrder?

  createdAt DateTime @default(now())
}

// ============================================================
// ORDENS DE SERVIÇO
// ============================================================

model ServiceOrder {
  id             String    @id @default(cuid())
  userId         String
  osNumber       String    @unique
  cotacaoId      String?   @unique
  equipmentId    String
  bookingId      String?   @unique
  clienteNome    String
  clienteTel     String?
  operatorName   String?
  status         String    @default("pending")

  startDate      DateTime
  endDate        DateTime
  actualStart    DateTime?
  actualEnd      DateTime?

  serviceAddress String?
  serviceCity    String?
  serviceNotes   String?   @db.Text

  totalDays      Int?
  dailyRate      Float?
  totalAmount    Float?

  cotacao        Cotacao?  @relation(fields: [cotacaoId], references: [id])
  equipment      Equipment @relation(fields: [equipmentId], references: [id])
  booking        Booking?  @relation(fields: [bookingId], references: [id])
  invoice        Invoice?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ============================================================
// MANUTENÇÃO
// ============================================================

model MaintenanceRecord {
  id              String    @id @default(cuid())
  userId          String
  equipmentId     String
  maintenanceType String
  description     String    @db.Text
  provider        String?
  cost            Float?
  startDate       DateTime
  endDate         DateTime?
  hoursAtService  Float?
  status          String    @default("scheduled")
  notes           String?   @db.Text

  equipment       Equipment @relation(fields: [equipmentId], references: [id])

  createdAt       DateTime  @default(now())
}

// ============================================================
// FATURAS
// ============================================================

model Invoice {
  id             String    @id @default(cuid())
  userId         String
  invoiceNumber  String    @unique
  serviceOrderId String?   @unique
  clienteNome    String
  clienteTel     String?
  clienteEmail   String?
  clienteCnpjCpf String?
  status         String    @default("draft")

  issueDate      DateTime  @default(now())
  dueDate        DateTime
  amount         Float
  taxAmount      Float     @default(0)
  totalAmount    Float
  paymentMethod  String?
  paidAt         DateTime?
  notes          String?   @db.Text

  municipalityConfigId String?
  municipalityConfig   MunicipalityTaxConfig? @relation(fields: [municipalityConfigId], references: [id])

  rpsNumber            Int?
  rpsSeries            String?
  nfseNumber           String?
  nfseVerificationCode String?
  nfsePdfUrl           String?
  nfseXml              String?   @db.Text
  providerProtocol     String?
  providerResponse     Json?
  errorMessage         String?   @db.Text
  emittedAt            DateTime?
  cancelledAt          DateTime?
  whatsappSentAt       DateTime?
  whatsappMessageId    String?

  serviceOrder   ServiceOrder? @relation(fields: [serviceOrderId], references: [id])
  receivable     Receivable?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ============================================================
// FISCAL — Configuração por Município
// ============================================================

model NfseProvider {
  id           String  @id @default(cuid())
  name         String  @unique
  baseUrl      String
  authType     String
  isActive     Boolean @default(true)

  municipalities MunicipalityTaxConfig[]

  createdAt DateTime @default(now())
}

model MunicipalityTaxConfig {
  id          String  @id @default(cuid())
  ibgeCode    String  @unique
  cityName    String
  state       String  @db.Char(2)
  providerId  String
  provider    NfseProvider @relation(fields: [providerId], references: [id])

  providerCredentials Json?
  issRate            Float?
  serviceCode        String?
  serviceDescription String?
  requiresRps        Boolean @default(true)
  nfseEnvironment    String  @default("homologacao")
  isActive           Boolean @default(true)

  invoices           Invoice[]
  companyConfigs     CompanyFiscalConfig[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// FISCAL — Configuração da Empresa
// ============================================================

model CompanyFiscalConfig {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  municipalityConfigId String
  municipalityConfig   MunicipalityTaxConfig @relation(fields: [municipalityConfigId], references: [id])

  nfeApiKey    String
  nfeCompanyId String

  razaoSocial        String?
  cnpj               String?
  inscricaoMunicipal String?
  codigoServico      String?
  aliquotaIss        Float?

  ambiente     String  @default("homologacao")
  ativo        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// FINANCEIRO — Contas Bancárias
// ============================================================

model BankAccount {
  id            String  @id @default(cuid())
  userId        String
  bankName      String
  bankCode      String?
  agency        String?
  accountNumber String?
  accountType   String?

  integrationType   String?
  apiCredentials    Json?
  externalAccountId String?

  currentBalance   Float     @default(0)
  balanceUpdatedAt DateTime?
  isActive         Boolean   @default(true)

  transactions BankTransaction[]
  receivables  Receivable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// FINANCEIRO — Títulos a Receber
// ============================================================

model Receivable {
  id            String  @id @default(cuid())
  userId        String
  invoiceId     String? @unique
  invoice       Invoice?     @relation(fields: [invoiceId], references: [id])
  bankAccountId String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])

  clienteNome    String
  clienteCnpjCpf String?
  paymentMethod  String
  amount         Float
  dueDate        DateTime

  externalId  String?  @unique
  barcode     String?  @db.Text
  pixKey      String?
  pixQrcode   String?  @db.Text
  paymentUrl  String?

  status            String   @default("pending")
  paidAmount        Float?
  paidAt            DateTime?
  paymentMethodUsed String?

  fineAmount     Float @default(0)
  interestAmount Float @default(0)
  discountAmount Float @default(0)

  bankTransactionId String?         @unique
  bankTransaction   BankTransaction? @relation(fields: [bankTransactionId], references: [id])
  reconciledAt      DateTime?
  reconciledBy      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// FINANCEIRO — Extrato Bancário
// ============================================================

model BankTransaction {
  id            String      @id @default(cuid())
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  userId        String

  transactionDate  DateTime
  description      String
  amount           Float
  balanceAfter     Float?

  externalId          String? @unique
  documentNumber      String?
  counterpartDocument String?
  counterpartName     String?
  paymentType         String?

  reconciliationStatus String @default("pending")
  confidenceScore      Float?

  receivable         Receivable?
  reconciliationLogs ReconciliationLog[]

  importedAt DateTime @default(now())
}

// ============================================================
// FINANCEIRO — Log de Conciliação
// ============================================================

model ReconciliationLog {
  id                String  @id @default(cuid())
  userId            String
  bankTransactionId String
  bankTransaction   BankTransaction @relation(fields: [bankTransactionId], references: [id])
  receivableId      String?

  action          String
  performedBy     String?
  confidenceScore Float?
  notes           String? @db.Text

  createdAt DateTime @default(now())
}

// ============================================================
// MANUTENÇÃO PREDITIVA
// ============================================================

model HourMeter {
  id          String    @id @default(cuid())
  userId      String
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  reading     Float
  readingDate DateTime  @default(now())
  recordedBy  String?
  notes       String?   @db.Text

  createdAt   DateTime  @default(now())
}

model MaintenancePlan {
  id          String    @id @default(cuid())
  userId      String
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  name          String
  triggerType   String  @default("hours")
  intervalHours Float?
  intervalDays  Int?

  lastDoneAt    DateTime?
  lastDoneHours Float?
  nextDueAt     DateTime?
  nextDueHours  Float?

  estimatedCost Float?
  status        String  @default("active")

  alerts        MaintenanceAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MaintenanceAlert {
  id          String    @id @default(cuid())
  userId      String
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  planId      String?
  plan        MaintenancePlan? @relation(fields: [planId], references: [id])

  alertType     String
  message       String
  triggeredAt   Float?
  dueDate       DateTime?

  status        String  @default("pending")
  resolvedAt    DateTime?
  blocksBooking Boolean @default(false)

  whatsappSentAt    DateTime?
  whatsappMessageId String?

  createdAt DateTime @default(now())
}

model EquipmentCost {
  id          String    @id @default(cuid())
  userId      String
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  costType    String
  description String
  amount      Float
  costDate    DateTime  @default(now())

  maintenanceRecordId String?

  createdAt DateTime @default(now())
}

// ============================================================
// CONTRATOS E MEDIÇÕES
// ============================================================

model Contract {
  id          String    @id @default(cuid())
  userId      String
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  contractNumber String  @unique
  clienteNome    String
  clienteTel     String?
  clienteEmail   String?
  clienteCnpjCpf String?

  billingType    String  @default("daily")
  rate           Float

  totalContractValue Float?
  advancePercent     Float?
  advanceAmount      Float?

  currency       String  @default("BRL")

  startDate      DateTime
  endDate        DateTime?
  status         String  @default("active")

  siteAddress    String?
  siteCity       String?
  operatorName   String?
  notes          String? @db.Text

  measurements   Measurement[]
  invoices       ContractInvoice[]
  operatorAssignments OperatorAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Measurement {
  id         String   @id @default(cuid())
  userId     String
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id])

  measureDate  DateTime @default(now())
  hoursWorked  Float?
  daysWorked   Float?
  daysIdle     Float?
  idleRate     Float?
  amount       Float
  operatorName String?
  notes        String? @db.Text

  status       String  @default("pending")

  createdAt DateTime @default(now())
}

model ContractInvoice {
  id         String   @id @default(cuid())
  userId     String
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id])

  periodStart   DateTime
  periodEnd     DateTime
  totalMeasured Float
  totalAmount   Float
  invoiceId     String?

  status      String  @default("draft")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// ABASTECIMENTO / CONTROLE DE COMBUSTÍVEL
// ============================================================

model FuelSupply {
  id          String    @id @default(cuid())
  userId      String
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  supplyDate    DateTime @default(now())
  fuelType      String   @default("diesel")
  liters        Float
  pricePerLiter Float
  totalCost     Float

  meterType    String  @default("hourmeter")
  meterReading Float?

  supplier      String?
  invoiceNumber String?
  operatorName  String?
  notes         String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// IMPOSTOS
// ============================================================

model TaxSettings {
  id                      String   @id @default(cuid())
  companyId               String   @default("default") @map("company_id")
  regime                  String   @default("SIMPLES_NACIONAL")

  simplesAnexo            String?  @default("III") @map("simples_anexo")
  simplesAliquotaNominal  Decimal? @default(0.06) @map("simples_aliquota_nominal") @db.Decimal(5, 4)
  simplesFatorReducao     Decimal? @default(0.00) @map("simples_fator_reducao") @db.Decimal(5, 4)

  issAliquota             Decimal? @default(0.05) @map("iss_aliquota") @db.Decimal(5, 4)
  issMunicipio            String?  @default("") @map("iss_municipio")
  issCodigoServico        String?  @default("7.09") @map("iss_codigo_servico")

  irpjPercentualPresuncao Decimal? @default(0.08) @map("irpj_percentual_presuncao") @db.Decimal(5, 4)
  irpjAliquota            Decimal? @default(0.15) @map("irpj_aliquota") @db.Decimal(5, 4)
  irpjAdicionalAliquota   Decimal? @default(0.10) @map("irpj_adicional_aliquota") @db.Decimal(5, 4)
  irpjAdicionalLimite     Decimal? @default(20000) @map("irpj_adicional_limite_mensal") @db.Decimal(15, 2)

  csllPercentualPresuncao Decimal? @default(0.12) @map("csll_percentual_presuncao") @db.Decimal(5, 4)
  csllAliquota            Decimal? @default(0.09) @map("csll_aliquota") @db.Decimal(5, 4)

  pisRegime               String?  @default("CUMULATIVO") @map("pis_regime")
  pisAliquota             Decimal? @default(0.0065) @map("pis_aliquota") @db.Decimal(5, 4)

  cofinsRegime            String?  @default("CUMULATIVO") @map("cofins_regime")
  cofinsAliquota          Decimal? @default(0.03) @map("cofins_aliquota") @db.Decimal(5, 4)

  inssAliquotaPatronal    Decimal? @default(0.20) @map("inss_aliquota_patronal") @db.Decimal(5, 4)
  inssRatAliquota         Decimal? @default(0.03) @map("inss_rat_aliquota") @db.Decimal(5, 4)
  inssFap                 Decimal? @default(1.00) @map("inss_fap") @db.Decimal(5, 4)
  inssTermceirosAliquota  Decimal? @default(0.058) @map("inss_terceiros_aliquota") @db.Decimal(5, 4)

  fgtsAliquota            Decimal? @default(0.08) @map("fgts_aliquota") @db.Decimal(5, 4)

  ativo                   Boolean  @default(true)
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("tax_settings")
}

model TaxApuration {
  id                     String    @id @default(cuid())
  competencia            String    @unique
  regime                 String

  faturamentoBruto       Decimal   @default(0) @map("faturamento_bruto") @db.Decimal(15, 2)
  deducoes               Decimal   @default(0) @db.Decimal(15, 2)
  faturamentoLiquido     Decimal   @default(0) @map("faturamento_liquido") @db.Decimal(15, 2)
  folhaPagamento         Decimal   @default(0) @map("folha_pagamento") @db.Decimal(15, 2)

  simplesReceitaBruta12m Decimal?  @default(0) @map("simples_receita_bruta_12m") @db.Decimal(15, 2)
  simplesAliquotaEfetiva Decimal?  @default(0) @map("simples_aliquota_efetiva") @db.Decimal(7, 6)
  simplesValor           Decimal?  @default(0) @map("simples_valor") @db.Decimal(15, 2)
  simplesVencimento      DateTime? @map("simples_vencimento") @db.Date
  simplesPago            Boolean?  @default(false) @map("simples_pago")
  simplesDataPagamento   DateTime? @map("simples_data_pagamento") @db.Date

  issBase                Decimal?  @default(0) @map("iss_base") @db.Decimal(15, 2)
  issValor               Decimal?  @default(0) @map("iss_valor") @db.Decimal(15, 2)
  issVencimento          DateTime? @map("iss_vencimento") @db.Date
  issPago                Boolean?  @default(false) @map("iss_pago")
  issDataPagamento       DateTime? @map("iss_data_pagamento") @db.Date

  irpjBase               Decimal?  @default(0) @map("irpj_base") @db.Decimal(15, 2)
  irpjValor              Decimal?  @default(0) @map("irpj_valor") @db.Decimal(15, 2)
  irpjAdicional          Decimal?  @default(0) @map("irpj_adicional") @db.Decimal(15, 2)
  irpjTotal              Decimal?  @default(0) @map("irpj_total") @db.Decimal(15, 2)
  irpjVencimento         DateTime? @map("irpj_vencimento") @db.Date
  irpjPago               Boolean?  @default(false) @map("irpj_pago")
  irpjDataPagamento      DateTime? @map("irpj_data_pagamento") @db.Date

  csllBase               Decimal?  @default(0) @map("csll_base") @db.Decimal(15, 2)
  csllValor              Decimal?  @default(0) @map("csll_valor") @db.Decimal(15, 2)
  csllVencimento         DateTime? @map("csll_vencimento") @db.Date
  csllPago               Boolean?  @default(false) @map("csll_pago")
  csllDataPagamento      DateTime? @map("csll_data_pagamento") @db.Date

  pisBase                Decimal?  @default(0) @map("pis_base") @db.Decimal(15, 2)
  pisValor               Decimal?  @default(0) @map("pis_valor") @db.Decimal(15, 2)
  pisVencimento          DateTime? @map("pis_vencimento") @db.Date
  pisPago                Boolean?  @default(false) @map("pis_pago")
  pisDataPagamento       DateTime? @map("pis_data_pagamento") @db.Date

  cofinsBase             Decimal?  @default(0) @map("cofins_base") @db.Decimal(15, 2)
  cofinsValor            Decimal?  @default(0) @map("cofins_valor") @db.Decimal(15, 2)
  cofinsVencimento       DateTime? @map("cofins_vencimento") @db.Date
  cofinsPago             Boolean?  @default(false) @map("cofins_pago")
  cofinsDataPagamento    DateTime? @map("cofins_data_pagamento") @db.Date

  inssBaaseFolha         Decimal?  @default(0) @map("inss_base_folha") @db.Decimal(15, 2)
  inssPatronalValor      Decimal?  @default(0) @map("inss_patronal_valor") @db.Decimal(15, 2)
  inssRatValor           Decimal?  @default(0) @map("inss_rat_valor") @db.Decimal(15, 2)
  inssTermceirosValor    Decimal?  @default(0) @map("inss_terceiros_valor") @db.Decimal(15, 2)
  inssTotal              Decimal?  @default(0) @map("inss_total") @db.Decimal(15, 2)
  inssVencimento         DateTime? @map("inss_vencimento") @db.Date
  inssPago               Boolean?  @default(false) @map("inss_pago")
  inssDataPagamento      DateTime? @map("inss_data_pagamento") @db.Date

  fgtsBase               Decimal?  @default(0) @map("fgts_base") @db.Decimal(15, 2)
  fgtsValor              Decimal?  @default(0) @map("fgts_valor") @db.Decimal(15, 2)
  fgtsVencimento         DateTime? @map("fgts_vencimento") @db.Date
  fgtsPago               Boolean?  @default(false) @map("fgts_pago")
  fgtsDataPagamento      DateTime? @map("fgts_data_pagamento") @db.Date

  totalImpostos          Decimal   @default(0) @map("total_impostos") @db.Decimal(15, 2)
  totalPago              Decimal   @default(0) @map("total_pago") @db.Decimal(15, 2)
  totalPendente          Decimal   @default(0) @map("total_pendente") @db.Decimal(15, 2)

  observacoes            String?
  status                 String    @default("RASCUNHO")

  pagamentos             TaxPayment[]

  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@index([competencia])
  @@map("tax_apurations")
}

model TaxPayment {
  id            String    @id @default(cuid())
  apurationId   String?   @map("apuration_id")
  competencia   String
  tributo       String
  descricao     String
  valor         Decimal   @db.Decimal(15, 2)
  vencimento    DateTime  @db.Date
  dataPagamento DateTime? @map("data_pagamento") @db.Date
  status        String    @default("PENDENTE")
  numeroGuia    String?   @map("numero_guia")
  banco         String?
  observacoes   String?

  apuration     TaxApuration? @relation(fields: [apurationId], references: [id])

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([competencia])
  @@index([status])
  @@index([vencimento])
  @@map("tax_payments")
}

// ============================================================
// OPERADORES
// ============================================================

model Operator {
  id     String @id @default(cuid())
  userId String

  // Cadastro pessoal
  nome     String
  cpf      String?
  rg       String?
  telefone String?
  email    String?

  // Endereço
  endereco  String?
  cidade    String?
  estado    String?
  cep       String?

  // CNH
  cnhNumero    String?
  cnhCategoria String? // A, B, C, D, E, AB, etc.
  cnhValidade  DateTime?

  // Pagamento
  // fixed | daily | hourly
  paymentType   String  @default("daily")
  salarioFixo   Float?  // usado quando paymentType = fixed
  valorDiaria   Float?  // usado quando paymentType = daily
  valorHora     Float?  // usado quando paymentType = hourly

  status String @default("active") // active | inactive

  notes String? @db.Text

  workLogs            OperatorWorkLog[]
  operatorAssignments OperatorAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Vínculo entre Operador ↔ Equipamento ↔ Contrato
model OperatorAssignment {
  id         String @id @default(cuid())
  userId     String
  operatorId String
  operator   Operator  @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  equipmentId String?
  equipment   Equipment? @relation(fields: [equipmentId], references: [id])

  contractId String?
  contract   Contract?  @relation(fields: [contractId], references: [id])

  startDate DateTime
  endDate   DateTime?
  notes     String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Controle de jornada — horas trabalhadas por dia/contrato
model OperatorWorkLog {
  id         String   @id @default(cuid())
  userId     String
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  workDate     DateTime @default(now())
  hoursWorked  Float
  contractId   String?
  equipmentId  String?

  // Valor calculado no momento do registro
  // (baseado no paymentType do operador naquela data)
  paymentType  String? // fixed | daily | hourly
  amountDue    Float?

  notes String? @db.Text

  createdAt DateTime @default(now())
}
