// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTENTICAÇÃO
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?

  plan          String    @default("free")
  planExpiresAt DateTime?
  trialEndsAt   DateTime?

  accounts  Account[]
  sessions  Session[]
  payments  Payment[]
  cotacoes  Cotacao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  mpPaymentId String   @unique
  planId      String
  amount      Float
  status      String   @default("pending")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// COTAÇÕES
// ============================================================

model Cotacao {
  id           String  @id @default(cuid())
  userId       String
  clienteNome  String
  clienteEmail String?
  clienteTel   String?
  descricao    String  @db.Text
  valor        Float?
  status       String  @default("rascunho")
  observacoes  String? @db.Text

  equipmentId  String?
  equipment    Equipment? @relation(fields: [equipmentId], references: [id])

  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  serviceOrder ServiceOrder?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// FROTA
// ============================================================

model Equipment {
  id           String  @id @default(cuid())
  userId       String
  name         String
  type         String
  brand        String?
  model        String?
  year         Int?
  plate        String?
  serialNumber String?
  capacityTons Float?
  status       String  @default("available")
  dailyRate    Float?
  hourlyRate   Float?
  notes        String? @db.Text

  photos        EquipmentPhoto[]
  documents     EquipmentDocument[]
  specs         EquipmentSpec[]
  bookings      Booking[]
  serviceOrders ServiceOrder[]
  maintenance   MaintenanceRecord[]
  cotacoes      Cotacao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EquipmentPhoto {
  id          String    @id @default(cuid())
  equipmentId String
  url         String
  isCover     Boolean   @default(false)
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model EquipmentDocument {
  id          String    @id @default(cuid())
  equipmentId String
  docType     String
  name        String
  url         String
  expiresAt   DateTime?
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model EquipmentSpec {
  id          String    @id @default(cuid())
  equipmentId String
  key         String
  value       String
  unit        String?
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
}

// ============================================================
// AGENDAMENTOS
// ============================================================

model Booking {
  id          String    @id @default(cuid())
  userId      String
  equipmentId String
  title       String
  startDate   DateTime
  endDate     DateTime
  bookingType String    @default("confirmed")
  notes       String?   @db.Text
  clientName  String?

  equipment    Equipment     @relation(fields: [equipmentId], references: [id])
  serviceOrder ServiceOrder?

  createdAt DateTime @default(now())
}

// ============================================================
// ORDENS DE SERVIÇO
// ============================================================

model ServiceOrder {
  id             String    @id @default(cuid())
  userId         String
  osNumber       String    @unique
  cotacaoId      String?   @unique
  equipmentId    String
  bookingId      String?   @unique
  clienteNome    String
  clienteTel     String?
  operatorName   String?
  status         String    @default("pending")

  startDate      DateTime
  endDate        DateTime
  actualStart    DateTime?
  actualEnd      DateTime?

  serviceAddress String?
  serviceCity    String?
  serviceNotes   String?   @db.Text

  totalDays      Int?
  dailyRate      Float?
  totalAmount    Float?

  cotacao        Cotacao?  @relation(fields: [cotacaoId], references: [id])
  equipment      Equipment @relation(fields: [equipmentId], references: [id])
  booking        Booking?  @relation(fields: [bookingId], references: [id])
  invoice        Invoice?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ============================================================
// MANUTENÇÃO
// ============================================================

model MaintenanceRecord {
  id              String    @id @default(cuid())
  userId          String
  equipmentId     String
  maintenanceType String
  description     String    @db.Text
  provider        String?
  cost            Float?
  startDate       DateTime
  endDate         DateTime?
  hoursAtService  Float?
  status          String    @default("scheduled")
  notes           String?   @db.Text

  equipment       Equipment @relation(fields: [equipmentId], references: [id])

  createdAt       DateTime  @default(now())
}

// ============================================================
// FATURAS
// ============================================================

model Invoice {
  id             String    @id @default(cuid())
  userId         String
  invoiceNumber  String    @unique
  serviceOrderId String?   @unique
  clienteNome    String
  clienteTel     String?
  clienteEmail   String?
  status         String    @default("draft")

  issueDate      DateTime  @default(now())
  dueDate        DateTime
  amount         Float
  taxAmount      Float     @default(0)
  totalAmount    Float
  paymentMethod  String?
  paidAt         DateTime?
  notes          String?   @db.Text

  serviceOrder   ServiceOrder? @relation(fields: [serviceOrderId], references: [id])

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
